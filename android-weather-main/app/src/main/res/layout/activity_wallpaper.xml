<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/wallpaper_act"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="#F0F2F5"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".ChangeWallpaper">

    <!-- 顶部工具栏 -->
    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        app:contentInsetStart="0dp"
        app:popupTheme="@style/AppTheme.PopupOverlay">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/glass_btn_back"
            android:padding="10dp"
            android:src="@mipmap/icon_back_black" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05"
            android:text="个性背景"
            android:textColor="#1A1A2E"
            android:textSize="18sp" />

    </androidx.appcompat.widget.Toolbar>

    <!-- 壁纸网格列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/wallpaper_con"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="16dp"
        android:paddingTop="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:overScrollMode="never" />

    <!-- 底部按钮区域 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <Button
            android:id="@+id/bg_img"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/glass_pill_btn"
            android:fontFamily="sans-serif-light"
            android:text="从本地相册选取"
            android:textColor="#1A1A2E"
            android:textSize="15sp" />

    </RelativeLayout>

</LinearLayout>
