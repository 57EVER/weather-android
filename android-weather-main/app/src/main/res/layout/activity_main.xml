<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/more_air_bg"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- 主容器，轻度暗化遮罩 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#33000000"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <!-- 顶部工具栏 -->
        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            app:contentInsetStart="0dp"
            app:popupTheme="@style/AppTheme.PopupOverlay">

            <ImageButton
                android:id="@+id/btn_map"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/glass_card_dark"
                android:padding="10dp"
                android:src="@mipmap/icon_map" />

            <TextView
                android:id="@+id/tv_city"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05"
                android:text="城市"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <ImageView
                android:id="@+id/iv_add"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end"
                android:background="@drawable/glass_card_dark"
                android:padding="12dp"
                android:src="@mipmap/icon_add" />

        </androidx.appcompat.widget.Toolbar>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingBottom="32dp">

                <!-- ===== 主天气卡片 ===== -->
                <LinearLayout
                    android:id="@+id/lay_slide_area"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/glass_card_bg"
                    android:orientation="vertical"
                    android:paddingLeft="28dp"
                    android:paddingRight="28dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="20dp">

                    <!-- 温度区域 -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <!-- 大温度字 -->
                        <TextView
                            android:id="@+id/tv_temperature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:fontFamily="sans-serif-thin"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textSize="88sp" />

                        <!-- 度数符号 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_toRightOf="@id/tv_temperature"
                            android:layout_marginTop="20dp"
                            android:fontFamily="sans-serif-light"
                            android:text="℃"
                            android:textColor="#AAFFFFFF"
                            android:textSize="28sp" />
                    </RelativeLayout>

                    <!-- 天气描述 + 最低最高温 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_Weather"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-light"
                            android:letterSpacing="0.06"
                            android:text="--"
                            android:textColor="#CCFFFFFF"
                            android:textSize="16sp" />

                        <!-- 最低温 -->
                        <TextView
                            android:id="@+id/tv_minTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:textColor="#88FFFFFF"
                            android:textSize="13sp" />

                        <!-- 最高温 -->
                        <TextView
                            android:id="@+id/tv_maxTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/divider_white" />

                    <!-- 预警 / 每日一句 + 更新时间 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_notify"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="marquee"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:fontFamily="sans-serif-light"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:singleLine="true"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_lastTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="上次更新时间："
                            android:textColor="#66FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/divider_white" />

                    <!-- 降水预告行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:animateLayoutChanges="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@mipmap/icon_weather_prec"
                            android:alpha="0.75" />

                        <TextView
                            android:id="@+id/tv_precipitation"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-light"
                            android:text="降水预告"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_precMore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="查看详情 ›"
                            android:textColor="#88FFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- 降水详情列表（展开时显示） -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/fore_rain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="0dp"
                        android:paddingTop="8dp"
                        android:paddingRight="0dp"
                        android:visibility="gone" />

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/divider_white" />

                    <!-- 小时预报 -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/hoursWeather"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- ===== 日预报卡片 ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/glass_card_bg"
                    android:orientation="vertical"
                    android:paddingLeft="8dp"
                    android:paddingTop="16dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="8dp">

                    <!-- 标题行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:paddingBottom="8dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@mipmap/icon_weather_sun"
                            android:alpha="0.7" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-light"
                            android:letterSpacing="0.08"
                            android:text="未来天气"
                            android:textColor="#99FFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_moreDays"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="更多天气预报 ›"
                            android:textColor="#88FFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- 7天预报列表 -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/daysWeather"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="4dp"
                        android:paddingRight="4dp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

</LinearLayout>
