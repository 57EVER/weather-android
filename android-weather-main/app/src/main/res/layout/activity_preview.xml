<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/preview"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".Preview">

    <!-- 天气预览区（上部） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:background="@color/transparent_bg_2"
        android:fitsSystemWindows="true"
        android:orientation="vertical"
        android:animateLayoutChanges="true">

        <!-- 工具栏 -->
        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            app:contentInsetStart="0dp"
            app:popupTheme="@style/AppTheme.PopupOverlay">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/glass_card_dark"
                android:padding="10dp"
                android:src="@mipmap/icon_map" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05"
                android:text="北京"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end"
                android:background="@drawable/glass_card_dark"
                android:padding="12dp"
                android:src="@mipmap/icon_add" />

        </androidx.appcompat.widget.Toolbar>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingLeft="20dp"
                android:paddingRight="20dp">

                <!-- 玻璃主卡片（预览用静态展示） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/glass_card_bg"
                    android:orientation="vertical"
                    android:paddingLeft="28dp"
                    android:paddingRight="28dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="20dp">

                    <!-- 温度 -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tv_temperature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:fontFamily="sans-serif-thin"
                            android:text="25"
                            android:textColor="#FFFFFF"
                            android:textSize="88sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginTop="20dp"
                            android:layout_toRightOf="@id/tv_temperature"
                            android:fontFamily="sans-serif-light"
                            android:text="℃"
                            android:textColor="#AAFFFFFF"
                            android:textSize="28sp" />
                    </RelativeLayout>

                    <!-- 天气描述 + 最低/最高温 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_Weather"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-light"
                            android:letterSpacing="0.06"
                            android:text="晴"
                            android:textColor="#CCFFFFFF"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tv_minTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="15 ~"
                            android:textColor="#88FFFFFF"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_maxTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text=" 25℃"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/divider_white" />

                    <!-- 底部信息行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-light"
                            android:text="Happy Every Day"
                            android:textColor="#AAFFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="上次更新时间：上午8:00"
                            android:textColor="#66FFFFFF"
                            android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- 底部操作区 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#44000000"
        android:gravity="center_horizontal">

        <ImageButton
            android:id="@+id/back_func"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="24dp"
            android:background="@drawable/glass_card_dark"
            android:padding="12dp"
            android:src="@mipmap/icon_return_white" />

        <Button
            android:id="@+id/wallpaper_apply"
            android:layout_width="180dp"
            android:layout_height="48dp"
            android:layout_centerInParent="true"
            android:background="@drawable/glass_pill_btn"
            android:fontFamily="sans-serif-light"
            android:text="应用壁纸"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

    </RelativeLayout>

</LinearLayout>
